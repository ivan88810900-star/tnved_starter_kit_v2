# === Скопируйте в customs-clear/backend/.env и подставьте секреты ===

# --- ИИ (хотя бы один ключ) ---
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL_NAME=claude-3-7-sonnet-20250219
GEMINI_API_KEY=AIza...
GEMINI_MODEL_NAME=gemini-1.5-flash

# --- База данных ---
DATABASE_URL=sqlite:///./customs.db
# DATABASE_URL=postgresql+psycopg2://customs:customs@127.0.0.1:5432/customs

# --- Auth (смените в проде) ---
SECRET_KEY=your-secret-key-min-32-chars-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480
ADMIN_PASSWORD=change-me-admin-password
VIEWER_PASSWORD=change-me-viewer-password
DECLARANT_PASSWORD=change-me-declarant-password
# Минимальная роль для POST /api/documents/ved-report-pdf (пусто = PDF без JWT)
# VED_EXPORT_MIN_ROLE=declarant

# --- Локальный ONNX-классификатор ТН ВЭД (pip install -r requirements-ml.txt) ---
# ONNX_HS_CLASSIFIER_PATH=/path/to/model.onnx
# ONNX_HS_LABELS_PATH=/path/to/labels.json
# ONNX_HS_FEATURE_DIM=128

# --- Доп. алиасы колонок Excel (packing list под заказчика) ---
# EXTRACTOR_COLUMN_ALIASES_JSON=/path/to/aliases.json

# --- HTTP ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://127.0.0.1:8001
MAX_UPLOAD_SIZE_MB=20
OCR_LANGUAGES=rus+chi_sim+eng
# --- Proxy для Google Gemini (раскомментируйте при необходимости) ---
# HTTP_PROXY=http://127.0.0.1:10809
# HTTPS_PROXY=http://127.0.0.1:10809

# --- Нормативка / синхронизация ---
NORMATIVE_FEED_URL=
NORMATIVE_CSV_URL=
ETT_PDF_MAX_GROUPS=3
# ETT_ODATA_REGISTRY_NAMES=

# --- Внешний классификатор ТН ВЭД (HTTP) ---
# CUSTOM_CLASSIFIER_ENABLED=true
# CUSTOM_CLASSIFIER_URL=https://your-inference.example/classify
# Локальный стаб для разработки: PYTHONPATH=. python scripts/inference_classifier_stub.py
# CUSTOM_CLASSIFIER_URL=http://127.0.0.1:8765/classify
# CUSTOM_CLASSIFIER_API_KEY=
# CUSTOM_CLASSIFIER_MODE=first_custom
# first_custom | first_llm | custom_only
# CUSTOM_CLASSIFIER_TIMEOUT=45
# Тело POST (опционально): JSON с плейсхолдером %s под JSON-строку описания, напр. {"text":%s}
# Стаб: INFERENCE_STUB_API_KEY — тогда задайте тот же ключ в CUSTOM_CLASSIFIER_API_KEY

# --- Лимит запросов API ---
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_PER_MINUTE=120
# Параллельные полные ВЭД-разборы (остальные ждут слот): по умолчанию 4, макс. 64
# VED_INTEL_MAX_CONCURRENT=4

# --- ТРОИС: доп. бренды из файла (POST /api/trois/reload-cache) ---
# TROIS_EXTRA_BRANDS_PATH=/path/to/extra_brands.json

# --- ФСА / разрешения ---
PERMITS_VERIFY_SSL=true
FSA_REQUEST_DELAY=2.0
FSA_RETRIES=2
FSA_EXTERNAL_API_URL=
# FSA_CERT_URL=https://pub.fsa.gov.ru/rss/certificate
# FSA_DECL_URL=https://pub.fsa.gov.ru/rds/declaration

# --- Redis (пусто = только память процесса) ---
# REDIS_URL=redis://127.0.0.1:6379/0
CACHE_TTL_SECONDS=3600
PERMITS_CACHE_TTL_SECONDS=3600
TROIS_CACHE_TTL_SECONDS=7200

# --- Планировщик в процессе uvicorn ---
# SCHEDULER_ENABLED=true
# SCHEDULER_SYNC_INTERVAL_HOURS=24

# --- Админ-операции (экспорт журнала, сброс кэша ФСА) ---
ADMIN_API_TOKEN=change-me-admin-api-token

# --- Аудит JSONL ---
# AUDIT_LOG_ENABLED=true
# AUDIT_LOG_PATH=data/audit_events.jsonl

# --- RAG (путь от каталога backend) ---
RAG_DOCS_DIR=../docs/rag_sources
# RAG_CHUNK_SIZE=480
# RAG_CHUNK_STEP=240
# RAG_MAX_PER_FILE=2
# RAG_MAX_CHUNKS_PER_FILE=48
# RAG_USE_TFIDF=false
# RAG_TFIDF_POOL=64
# RAG_CHROMA_PATH=./data/chroma_rag
# RAG_CHROMA_COLLECTION=customs_clear_rag

# --- Copilot batch ---
# COPILOT_BATCH_CONCURRENCY=4

# --- Журнал подтверждений ТН ВЭД ---
DECISIONS_LOG_PATH=data/user_decisions.jsonl
# DECISIONS_LOG_MAX_READ=5000
# DECISIONS_SIMILAR_ENABLED=true
# DECISIONS_SIMILAR_LIMIT=6
# DECISIONS_SIMILAR_MIN_SCORE=0.18
# DECISIONS_CLASSIFIER_HINTS=true
# DECISIONS_CLIENT_BOOST_MULT=1.28

# --- Альта-Софт XML-API (договор + логин; docs/integration/) ---
# ALTA_HTTP_TIMEOUT=45
# ALTA_TIK_ENABLED=true
# ALTA_TIK_LOGIN=
# ALTA_TIK_PASSWORD=
# ALTA_TIK_BASE_URL=https://www.alta.ru/tik/xml/
# ALTA_APU_ENABLED=true
# ALTA_APU_LOGIN=
# ALTA_APU_PASSWORD=
# ALTA_APU_BASE_URL=https://www.alta.ru/tnved/xml_apu/

# Полный справочник: docs/ENVIRONMENT.md
