# Шаблон переменных: скопируйте ../.env.example → сюда как файл `.env`
# или объедините оба файла в один .env в этом каталоге (откуда запускается uvicorn).

# LLM: основной провайдер — Anthropic Claude Haiku (работает из РФ без proxyapi)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_NAME=claude-haiku-4-5-20251001
ANTHROPIC_VISION_MODEL=claude-haiku-4-5-20251001

# Fallback: Google Gemini (через AI Studio или GEMINI_BASE_URL proxy)
GEMINI_API_KEY=

# API-прокси Gemini (опционально): только домен, без https://
# GEMINI_BASE_URL=api.proxyapi.ru

# Proxy для Google Gemini (раскомментируйте при необходимости):
# HTTP_PROXY=http://127.0.0.1:10809
# HTTPS_PROXY=http://127.0.0.1:10809
