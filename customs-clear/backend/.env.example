# Шаблон переменных: скопируйте ../.env.example → сюда как файл `.env`
# или объедините оба файла в один .env в этом каталоге (откуда запускается uvicorn).

# ИИ-чат декларанта (Google AI Studio) — обязательно для /api/v1/assistant/chat
GEMINI_API_KEY=

# API-прокси: в SDK только домен (без https:// и без /v1beta), например api.proxyapi.ru или api.bothub.chat
# GEMINI_BASE_URL=api.proxyapi.ru

# Proxy для Google Gemini (раскомментируйте при необходимости):
# HTTP_PROXY=http://127.0.0.1:10809
# HTTPS_PROXY=http://127.0.0.1:10809
