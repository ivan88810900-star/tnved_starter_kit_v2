{
  "name": "customs-clear",
  "version": "1.0.0",
  "description": "CustomsClear — проверка таможенных документов",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "node build.js",
    "build:mac": "node build.js mac",
    "build:win": "node build.js win",
    "build:win-frontend-only": "node build.js win --frontend-only",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^2.1.8",
    "sharp": "^0.34.0"
  },
  "build": {
    "appId": "ru.customsclear.app",
    "productName": "CustomsClear",
    "directories": {
      "output": "dist",
      "buildResources": "build-resources"
    },
    "files": [
      "main.js",
      "backend/**/*"
    ],
    "extraResources": [
      {
        "from": "backend/",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build-resources/icon.icns",
      "hardenedRuntime": true
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build-resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
